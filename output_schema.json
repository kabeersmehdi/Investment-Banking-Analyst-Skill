{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M&A Analyst Agent Output Schema v3.0",
  "type": "object",
  "properties": {
    "deal_context_status": {
      "type": "object",
      "properties": {
        "onboarding_complete": {"type": "boolean"},
        "required_fields_missing": {"type": "array", "items": {"type": "string"}},
        "outputs_generated": {"type": "array", "items": {"type": "string"}},
        "last_updated": {"type": "string"}
      }
    },
    "valuation": {
      "type": "object",
      "properties": {
        "normalized_sde": {"type": "number"},
        "normalized_ebitda": {"type": "number"},
        "revenue_quality_score": {"type": "number"},
        "multiple_range": {
          "type": "object",
          "properties": {
            "low": {"type": "number"},
            "mid": {"type": "number"},
            "high": {"type": "number"},
            "source_type": {"type": "string"}
          }
        },
        "adjustments_applied": {"type": "array", "items": {"type": "string"}},
        "enterprise_value_range": {
          "type": "object",
          "properties": {
            "bear": {"type": "number"},
            "base": {"type": "number"},
            "bull": {"type": "number"}
          }
        },
        "recommended_asking_price": {"type": "number"},
        "confidence": {"type": "string"},
        "sources": {"type": "array", "items": {"type": "object"}}
      }
    },
    "risk_auto_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk": {"type": "string"},
          "severity": {"type": "string"},
          "source_field": {"type": "string"},
          "mitigation": {"type": "string"}
        }
      }
    },
    "sba_feasibility": {
      "type": "object",
      "properties": {
        "eligible": {"type": "boolean"},
        "dscr": {"type": "number"},
        "monthly_payment": {"type": "number"},
        "post_ds_cash_flow": {"type": "number"},
        "current_rate": {"type": "number"},
        "rate_source": {"type": "string"}
      }
    },
    "seller_readiness": {
      "type": "object",
      "properties": {
        "ready_items": {"type": "array", "items": {"type": "string"}},
        "gaps": {"type": "array", "items": {"type": "string"}},
        "blockers": {"type": "array", "items": {"type": "string"}},
        "weeks_to_market_ready": {"type": "integer"}
      }
    },
    "master_source_log": {
      "type": "object",
      "properties": {
        "live_sources": {"type": "integer"},
        "embedded_benchmarks": {"type": "integer"},
        "quality_score": {"type": "number"},
        "sources": {"type": "array", "items": {"type": "object"}}
      }
    }
  }
}
