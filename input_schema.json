{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M&A Deal Context — Auto-populated from /start",
  "type": "object",
  "properties": {
    "company": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "codename": {"type": "string"},
        "description": {"type": "string"},
        "industry": {"type": "string"},
        "sub_industry": {"type": "string"},
        "naics_code": {"type": "string"},
        "location_state": {"type": "string"},
        "location_metro": {"type": "string"},
        "years_in_business": {"type": "integer"},
        "business_model": {"type": "string"}
      }
    },
    "financials": {
      "type": "object",
      "properties": {
        "revenue_ttm": {"type": "number"},
        "revenue_year_1": {"type": "number"},
        "revenue_year_2": {"type": "number"},
        "gross_profit_ttm": {"type": "number"},
        "net_income_ttm": {"type": "number"},
        "sde_ttm": {"type": "number"},
        "ebitda_ttm": {"type": "number"},
        "accounting_basis": {"type": "string"},
        "financial_records": {"type": "string"},
        "debt": {"type": "number"},
        "cash": {"type": "number"},
        "capex_annual": {"type": "number"}
      }
    },
    "add_backs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {"type": "string"},
          "amount": {"type": "number"},
          "recurring": {"type": "boolean"},
          "documented": {"type": "boolean"}
        }
      }
    },
    "owner_compensation": {
      "type": "object",
      "properties": {
        "total_comp": {"type": "number"},
        "market_rate_replacement": {"type": "number"}
      }
    },
    "customers": {
      "type": "object",
      "properties": {
        "total_active": {"type": "integer"},
        "top_1_pct": {"type": "number"},
        "top_3_pct": {"type": "number"},
        "top_10_pct": {"type": "number"},
        "top_customer_tenure_years": {"type": "number"},
        "contracts_in_place": {"type": "boolean"},
        "contract_length_months": {"type": "integer"},
        "avg_tenure_years": {"type": "number"},
        "lost_major_customers": {"type": "string"}
      }
    },
    "revenue_quality": {
      "type": "object",
      "properties": {
        "recurring_pct": {"type": "number"},
        "repeat_no_contract_pct": {"type": "number"},
        "project_based_pct": {"type": "number"},
        "seasonality": {"type": "string"}
      }
    },
    "operations": {
      "type": "object",
      "properties": {
        "owner_role": {"type": "string"},
        "owner_hours_per_week": {"type": "integer"},
        "reason_for_sale": {"type": "string"},
        "owner_transition_months": {"type": "integer"},
        "family_in_business": {"type": "string"},
        "ft_employees": {"type": "integer"},
        "pt_contractors": {"type": "integer"},
        "has_number_2": {"type": "boolean"},
        "number_2_description": {"type": "string"},
        "key_roles": {"type": "array", "items": {"type": "string"}},
        "key_person_risk": {"type": "string"},
        "turnover": {"type": "string"},
        "facility_owned_or_leased": {"type": "string"},
        "lease_remaining_months": {"type": "integer"},
        "lease_renewal_options": {"type": "boolean"},
        "real_estate_in_sale": {"type": "boolean"}
      }
    },
    "deal_parameters": {
      "type": "object",
      "properties": {
        "asking_price": {"type": "number"},
        "structure_preference": {"type": "string"},
        "seller_note_max_pct": {"type": "number"},
        "sba_eligible": {"type": "boolean"},
        "target_close_months": {"type": "integer"},
        "previous_broker": {"type": "boolean"},
        "non_compete": {"type": "string"},
        "assets_included": {"type": "array", "items": {"type": "string"}},
        "assets_excluded": {"type": "array", "items": {"type": "string"}},
        "existing_offers": {"type": "string"}
      }
    },
    "broker_notes": {
      "type": "object",
      "properties": {
        "known_risks": {"type": "array", "items": {"type": "string"}},
        "selling_points": {"type": "array", "items": {"type": "string"}},
        "growth_opportunities": {"type": "array", "items": {"type": "string"}},
        "ideal_buyer_type": {"type": "string"},
        "seller_personality": {"type": "string"},
        "other_notes": {"type": "string"},
        "first_output_requested": {"type": "string"}
      }
    }
  }
}
